# Google OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID=your-client-id-here
GOOGLE_CLIENT_SECRET=your-client-secret-here

# OAuth Redirect URIs
GOOGLE_REDIRECT_URI_LOCAL=http://localhost:3001/auth/google/callback
GOOGLE_REDIRECT_URI_VERCEL=https://ga4-dashboard-two.vercel.app/auth/google/callback
GOOGLE_REDIRECT_URI=$GOOGLE_REDIRECT_URI_VERCEL

# Vercel Deployment
VERCEL_URL=ga4-dashboard-two.vercel.app
VERCEL_API_KEY=your-vercel-api-key

# GitHub
GITHUB_REPOSITORY=https://github.com/inakigorostiza/ga4-mcp-dashboard

# Session secret for express-session (generate a random string)
SESSION_SECRET=your-random-secret-key-here

# Server port
PORT=3001

# Google Cloud Project
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Google Application Credentials path (optional)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# Frontend URL for CORS
FRONTEND_URL=https://inakigorostiza.github.io/ga4-mcp-dashboard
